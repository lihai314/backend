# 应用名称
APP_NAME=backend
# 运行环境：local / dev / staging / production
ENVIRONMENT=local
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# 数据库连接 URL
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/backend
# Redis 连接 URL
REDIS_URL=redis://localhost:6379/0
# Session 有效期，默认 7 天
AUTH_SESSION_TTL_SECONDS=604800
# Redis session key 前缀
AUTH_SESSION_KEY_PREFIX=auth:session:
# session token 随机字节数
AUTH_SESSION_TOKEN_BYTES=32
